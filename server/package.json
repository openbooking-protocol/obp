{
  "name": "@obp/server",
  "version": "0.1.0",
  "description": "OpenBooking Protocol — Reference server implementation",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.15.0",
    "@types/nodemailer": "^7.0.11",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "nanoid": "^5.0.7",
    "nodemailer": "^8.0.2",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^20.14.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "drizzle-kit": "^0.21.4",
    "eslint": "^9.8.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
