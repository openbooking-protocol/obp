# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://obp:obp@localhost:5432/obp

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-at-least-32-chars
API_KEY_SALT=change-me-in-production

# Federation
SERVER_URL=http://localhost:3000
SERVER_NAME=OBP Development Server

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Logging
LOG_LEVEL=info
