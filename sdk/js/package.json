{
  "name": "@obp/client",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript client for the OpenBooking Protocol",
  "keywords": ["obp", "booking", "scheduling", "openapi", "typescript"],
  "license": "MIT",
  "author": "OpenBooking Protocol Contributors",
  "homepage": "https://github.com/openbooking-protocol/obp",
  "repository": {
    "type": "git",
    "url": "https://github.com/openbooking-protocol/obp.git",
    "directory": "sdk/js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsup": "^8.2.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
